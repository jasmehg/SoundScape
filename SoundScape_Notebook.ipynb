    "## Main Function: Event Loop\n",
    "\n",
    "The event loop handles mouse input for dragging and clicking ships. Mouse button down starts a drag \n",
    "if the click is on a ship. Mouse button up either ends the drag or, if the mouse didn't move much, \n",
    "registers a click and calls toggle_slow. Mouse motion while a button is held updates the ship's \n",
    "x and lane simultaneously, making the reroute permanent."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "while running:\n",
    "    dt = min(clock.tick(FPS) / 1000.0, 0.05)\n",
    "    mx, my = pygame.mouse.get_pos()\n",
    "\n",
    "    for event in pygame.event.get():\n",
    "        if event.type == pygame.QUIT:\n",
    "            running = False\n",
    "        if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:\n",
    "            mouse_was_down = True\n",
    "            if mx < OCEAN_W:\n",
    "                for s in ships:\n",
    "                    if not s.finished and s.check_click(mx, my):\n",
    "                        dragging = s\n",
    "                        s.being_dragged = True\n",
    "                        drag_offset_x = s.x - mx\n",
    "                        break\n",
    "        elif event.type == pygame.MOUSEBUTTONUP and event.button == 1:\n",
    "            if dragging:\n",
    "                dragging.being_dragged = False\n",
    "                dragging = None\n",
    "            elif mouse_was_down and mx < OCEAN_W:\n",
    "                for s in ships:\n",
    "                    if not s.finished and s.check_click(mx, my):\n",
    "                        s.toggle_slow()# click = slow toggle\n",
    "                        break\n",
    "        elif event.type == pygame.MOUSEMOTION and dragging:\n",
    "            new_x = max(20, min(OCEAN_W - 20, mx + drag_offset_x))\n",
    "            dragging.x    = new_x\n",
    "            dragging.lane = new_x# permanent reroute"
   ]
